# itsmemunia.xyz — munia-photography
# HTTP only — add SSL later with:
#   sudo certbot --nginx -d itsmemunia.xyz -d www.itsmemunia.xyz

server {
    listen 80;
    listen [::]:80;

    server_name itsmemunia.xyz www.itsmemunia.xyz;

    access_log  /var/log/nginx/itsmemunia.xyz.access.log;
    error_log   /var/log/nginx/itsmemunia.xyz.error.log;

    # Photography site may upload large images
    client_max_body_size 50M;

    location / {
        proxy_pass         http://127.0.0.1:8741;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
        proxy_connect_timeout 10s;
    }
}
